<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Test pro seniory: jste aktivní i v důchodu? Zkuste si to ověřit</title>
<style>
  * { box-sizing: border-box; }
  body {
    font-family: "Georgia", "Times New Roman", serif;
    background: #f5f0eb;
    color: #2c2c2c;
    margin: 0;
    padding: 40px 16px;
    line-height: 1.55;
  }
  .wrap {
    max-width: 720px;
    margin: 0 auto;
  }
  h1 {
    font-size: 1.9rem;
    line-height: 1.25;
    color: #2c2c2c;
    margin: 0 0 20px;
  }
  .perex {
    font-size: 1.1rem;
    color: #4a4a4a;
    margin: 0 0 36px;
  }
  .question {
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    padding: 28px;
    margin-bottom: 24px;
  }
  .q-text {
    font-weight: bold;
    font-size: 1.15rem;
    color: #2c2c2c;
    margin: 0 0 18px;
  }
  .option {
    display: block;
    width: 100%;
    text-align: left;
    padding: 14px 18px;
    background: #f7f4f0;
    border: 1px solid #d9d2c9;
    border-radius: 8px;
    cursor: pointer;
    font-size: 1rem;
    color: #3a3a3a;
    font-family: inherit;
    margin-bottom: 12px;
    transition: background 0.15s ease;
  }
  .option:last-child { margin-bottom: 0; }
  .option:hover:not(.locked) { background: #ede8e1; }
  .option.selected {
    background: #dcd3c7;
    border: 1px solid #a89e92;
    font-weight: bold;
  }
  .option.locked { cursor: default; }
  .option:focus-visible {
    outline: 2px solid #5b7e5f;
    outline-offset: 2px;
  }
  #evaluateBtn {
    background: #5b7e5f;
    color: #ffffff;
    padding: 16px 40px;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: bold;
    border: none;
    cursor: pointer;
    display: block;
    margin: 40px auto 0;
    font-family: inherit;
    transition: background 0.15s ease;
  }
  #evaluateBtn:hover:not(:disabled) { background: #4a6b4e; }
  #evaluateBtn:disabled {
    background: #b5b5b5;
    cursor: not-allowed;
  }
  #result {
    background: #fefcf9;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    border-top: 4px solid #5b7e5f;
    padding: 28px;
    margin-top: 32px;
  }
  .result-type {
    font-size: 2.5rem;
    font-weight: bold;
    color: #5b7e5f;
    text-align: center;
    margin: 0 0 16px;
    line-height: 1.2;
  }
  .result-text {
    font-size: 1rem;
    color: #4a4a4a;
    text-align: center;
    margin: 0 0 18px;
  }
  .result-text:last-child { margin-bottom: 0; }
  .tie-note {
    font-size: 1rem;
    color: #4a4a4a;
    text-align: center;
    margin: 0 0 22px;
    font-style: italic;
  }
  #retryBtn {
    background: #8c7b6b;
    color: #ffffff;
    padding: 16px 40px;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: bold;
    border: none;
    cursor: pointer;
    display: block;
    margin: 32px auto 0;
    font-family: inherit;
    transition: background 0.15s ease;
  }
  #retryBtn:hover { background: #756658; }
  .hidden { display: none; }
  #toast {
    position: fixed;
    left: 50%;
    bottom: 32px;
    transform: translateX(-50%) translateY(20px);
    background: #2c2c2c;
    color: #fff;
    padding: 14px 24px;
    border-radius: 8px;
    font-size: 1rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
    z-index: 100;
  }
  #toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  @media (max-width: 600px) {
    body { padding: 24px 16px; }
    h1 { font-size: 1.55rem; }
    .question { padding: 22px 18px; }
  }
</style>
</head>
<body>
<div class="wrap">
  <h1>Test pro seniory: jste aktivní i v důchodu? Zkuste si to ověřit</h1>
  <p class="perex">Důchod nemusí znamenat zpomalení, jen jinou podobu činorodosti. Někdo je pořád na nohou, jiný mezi lidmi, další má plné ruce práce a poslední hltá nové poznání. Odpovězte, milí senioři, na deset otázek a zjistěte, jak aktivní typ se ve vás skrývá.</p>

  <div id="quiz"></div>

  <button id="evaluateBtn" type="button" disabled>Vyhodnotit</button>

  <div id="result" class="hidden"></div>
</div>

<div id="toast" role="status" aria-live="polite"></div>

<script>
(function () {
  const questions = [
    {
      text: `1. Co vás ráno nejvíc žene z postele?`,
      options: [
        { letter: `a`, text: `chuť vyrazit ven, protáhnout tělo a nadechnout se čerstvého vzduchu` },
        { letter: `b`, text: `vyhlídka, že někoho uvidíte a strávíte čas ve společnosti` },
        { letter: `c`, text: `rozdělaná práce, kterou chcete konečně dotáhnout do konce` },
        { letter: `d`, text: `zvědavost, co nového se dnes dozvíte nebo naučíte` }
      ]
    },
    {
      text: `2. Jak naložíte s celým dnem, který máte jen pro sebe?`,
      options: [
        { letter: `a`, text: `vyrazíte na výlet, do přírody nebo někam, kde se pohnete` },
        { letter: `b`, text: `domluvíte si setkání a zajdete mezi lidi` },
        { letter: `c`, text: `pustíte se do něčeho doma, na zahradě nebo kolem domu` },
        { letter: `d`, text: `ponoříte se do knihy, kurzu nebo něčeho, co zaměstná hlavu` }
      ]
    },
    {
      text: `3. Jakou novou činnost si nejradši vyzkoušíte?`,
      options: [
        { letter: `a`, text: `nějaký pohyb, tanec nebo turistiku v neznámém kraji` },
        { letter: `b`, text: `klub nebo spolek, kde poznáte nové lidi` },
        { letter: `c`, text: `řemeslo, pěstování nebo práci, u které něco vznikne` },
        { letter: `d`, text: `cizí jazyk, přednášky nebo ovládání počítače` }
      ]
    },
    {
      text: `4. Jakou roli obvykle máte, když se sejde větší společnost?`,
      options: [
        { letter: `a`, text: `navrhnete, ať se jde ven, a rozhýbete ostatní` },
        { letter: `b`, text: `bavíte se se všemi a propojujete lidi mezi sebou` },
        { letter: `c`, text: `postaráte se o občerstvení a zázemí, ať vše klape` },
        { letter: `d`, text: `přinesete zajímavé téma a rozproudíte hovor` }
      ]
    },
    {
      text: `5. Jak se nejraději odměníte, když máte volno navíc?`,
      options: [
        { letter: `a`, text: `vyrazíte na výpravu, kde se hýbete a něco zažijete` },
        { letter: `b`, text: `pozvete někoho a strávíte čas ve společnosti` },
        { letter: `c`, text: `pořídíte si materiál nebo nářadí na nový projekt` },
        { letter: `d`, text: `dopřejete si knihu, přednášku nebo lístek do divadla` }
      ]
    },
    {
      text: `6. Jak pečujete o svou kondici?`,
      options: [
        { letter: `a`, text: `pravidelně chodíte, jezdíte na kole nebo cvičíte` },
        { letter: `b`, text: `hýbete se hlavně při akcích a setkáních s lidmi` },
        { letter: `c`, text: `udržujete se ve formě prací na zahradě a kolem domu` },
        { letter: `d`, text: `protahujete tělo v klidu a nejvíc trénujete hlavu` }
      ]
    },
    {
      text: `7. Co nejčastěji radíte někomu, kdo právě odchází do důchodu?`,
      options: [
        { letter: `a`, text: `ať se hýbe, chodí ven a nezůstává sedět doma` },
        { letter: `b`, text: `ať vyhledává lidi a nezůstává sám` },
        { letter: `c`, text: `ať si najde práci pro ruce, zahradu nebo koníček` },
        { letter: `d`, text: `ať se pořád něčemu učí a zaměstnává hlavu` }
      ]
    },
    {
      text: `8. Kde je vám nejlíp?`,
      options: [
        { letter: `a`, text: `venku, v pohybu a na čerstvém vzduchu` },
        { letter: `b`, text: `mezi lidmi, kde to žije` },
        { letter: `c`, text: `v dílně, na zahradě nebo u něčeho rozdělaného` },
        { letter: `d`, text: `v klidu u knihy nebo u něčeho, co zaměstná mysl` }
      ]
    },
    {
      text: `9. Bez čeho si svůj den nedovedete představit?`,
      options: [
        { letter: `a`, text: `bez pohybu a chvíle venku` },
        { letter: `b`, text: `bez kontaktu s někým blízkým` },
        { letter: `c`, text: `bez nějaké práce nebo činnosti kolem domu` },
        { letter: `d`, text: `bez chvíle pro knihu, zprávy nebo přemýšlení` }
      ]
    },
    {
      text: `10. Jak si představujete své další roky v důchodu?`,
      options: [
        { letter: `a`, text: `pořád na nohou, na cestách a v pohybu` },
        { letter: `b`, text: `mezi lidmi, kteří vám dělají radost` },
        { letter: `c`, text: `s rukama stále v práci, ať je co dělat` },
        { letter: `d`, text: `se stálou chutí učit se a poznávat nové` }
      ]
    }
  ];

  const profiles = {
    a: {
      name: `Věčný poutník`,
      text: `Sedět doma pro vás není. Nejvíc ožíváte v pohybu, na čerstvém vzduchu a na cestách, kde můžete něco nachodit a nadechnout se. Důchod berete jako čas, kdy konečně máte na výpravy a pohyb dost prostoru, a vaše energie mnohému mladšímu jen tak nedá spát.`
    },
    b: {
      name: `Duše společnosti`,
      text: `Vaší silou jsou lidé. Nejlíp je vám tam, kde to žije, kde se povídá a kde můžete být druhým nablízku. V důchodu rozkvétáte mezi přáteli a rodinou, spojujete lidi dohromady a málokterá sešlost se obejde bez vaší dobré nálady.`
    },
    c: {
      name: `Šikovné ruce`,
      text: `Klid vám nedá, dokud není něco hotové. Baví vás tvořit, pěstovat, opravovat a starat se o to, co máte kolem sebe. Důchod je pro vás časem, kdy máte konečně prostor pro všechny odložené projekty, a radost vám dělá výsledek, na který si můžete sáhnout.`
    },
    d: {
      name: `Zvídavý duch`,
      text: `Vaše zvědavost nezná věk. Pořád vás láká něco nového se dozvědět, přijít věcem na kloub a poznávat svět z nových stran. V důchodu si užíváte, že máte čas na knihy, kurzy a kulturu, a vaše mysl zůstává svěží a bystrá.`
    }
  };

  const answers = new Array(questions.length).fill(null);
  let locked = false;

  const quizEl = document.getElementById(`quiz`);
  const evaluateBtn = document.getElementById(`evaluateBtn`);
  const resultEl = document.getElementById(`result`);
  const toastEl = document.getElementById(`toast`);
  let toastTimer = null;

  function buildQuiz() {
    questions.forEach(function (q, qi) {
      const box = document.createElement(`div`);
      box.className = `question`;

      const qText = document.createElement(`p`);
      qText.className = `q-text`;
      qText.textContent = q.text;
      box.appendChild(qText);

      q.options.forEach(function (opt, oi) {
        const btn = document.createElement(`button`);
        btn.type = `button`;
        btn.className = `option`;
        btn.textContent = opt.letter + `) ` + opt.text;
        btn.setAttribute(`data-q`, qi);
        btn.setAttribute(`data-o`, oi);
        btn.addEventListener(`click`, function () {
          if (locked) return;
          answers[qi] = oi;
          const siblings = box.querySelectorAll(`.option`);
          siblings.forEach(function (s) { s.classList.remove(`selected`); });
          btn.classList.add(`selected`);
          updateEvaluateState();
        });
        box.appendChild(btn);
      });

      quizEl.appendChild(box);
    });
  }

  function updateEvaluateState() {
    const allAnswered = answers.every(function (a) { return a !== null; });
    evaluateBtn.disabled = !allAnswered;
  }

  function showToast(msg) {
    toastEl.textContent = msg;
    toastEl.classList.add(`show`);
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(function () {
      toastEl.classList.remove(`show`);
    }, 2600);
  }

  function evaluate() {
    if (answers.some(function (a) { return a === null; })) {
      showToast(`Odpovězte prosím na všechny otázky`);
      return;
    }

    locked = true;

    // Uzamčení všech tlačítek
    const allOptions = quizEl.querySelectorAll(`.option`);
    allOptions.forEach(function (o) { o.classList.add(`locked`); });

    // Spočítání písmen
    const tally = { a: 0, b: 0, c: 0, d: 0 };
    answers.forEach(function (oi, qi) {
      const letter = questions[qi].options[oi].letter;
      tally[letter] += 1;
    });

    const max = Math.max(tally.a, tally.b, tally.c, tally.d);
    const winners = [`a`, `b`, `c`, `d`].filter(function (l) { return tally[l] === max; });

    resultEl.innerHTML = ``;

    if (winners.length === 1) {
      const p = profiles[winners[0]];
      const nameEl = document.createElement(`p`);
      nameEl.className = `result-type`;
      nameEl.textContent = p.name;
      resultEl.appendChild(nameEl);

      const textEl = document.createElement(`p`);
      textEl.className = `result-text`;
      textEl.textContent = p.text;
      resultEl.appendChild(textEl);
    } else {
      const note = document.createElement(`p`);
      note.className = `tie-note`;
      note.textContent = `Máte shodně nejvíc odpovědí u více typů — hodí se k vám každý z nich:`;
      resultEl.appendChild(note);

      winners.forEach(function (l) {
        const p = profiles[l];
        const nameEl = document.createElement(`p`);
        nameEl.className = `result-type`;
        nameEl.textContent = p.name;
        resultEl.appendChild(nameEl);

        const textEl = document.createElement(`p`);
        textEl.className = `result-text`;
        textEl.textContent = p.text;
        resultEl.appendChild(textEl);
      });
    }

    const retryBtn = document.createElement(`button`);
    retryBtn.type = `button`;
    retryBtn.id = `retryBtn`;
    retryBtn.textContent = `Zkusit znovu`;
    retryBtn.addEventListener(`click`, reset);
    resultEl.appendChild(retryBtn);

    resultEl.classList.remove(`hidden`);
    evaluateBtn.classList.add(`hidden`);

    resultEl.scrollIntoView({ behavior: `smooth`, block: `start` });
  }

  function reset() {
    for (let i = 0; i < answers.length; i++) answers[i] = null;
    locked = false;

    const allOptions = quizEl.querySelectorAll(`.option`);
    allOptions.forEach(function (o) {
      o.classList.remove(`selected`, `locked`);
    });

    resultEl.classList.add(`hidden`);
    resultEl.innerHTML = ``;
    evaluateBtn.classList.remove(`hidden`);
    evaluateBtn.disabled = true;

    window.scrollTo({ top: 0, behavior: `smooth` });
  }

  buildQuiz();
  evaluateBtn.addEventListener(`click`, evaluate);
})();
</script>
</body>
</html>
