<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Test pro seniory: zjistěte, jak mladý je váš mozek. Stačí 10 otázek a dozvíte se věk</title>
<style>
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: "Georgia", "Times New Roman", serif;
    background: #f5f0eb;
    color: #2c2c2c;
    margin: 0;
    padding: 40px 16px;
    line-height: 1.6;
  }
  .wrap {
    max-width: 720px;
    margin: 0 auto;
  }
  h1 {
    font-size: 1.9rem;
    line-height: 1.3;
    color: #2c2c2c;
    margin: 0 0 20px;
  }
  .perex {
    font-size: 1.1rem;
    color: #4a4a4a;
    margin: 0 0 32px;
  }
  .question {
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    padding: 28px;
    margin-bottom: 24px;
  }
  .q-text {
    font-weight: bold;
    font-size: 1.15rem;
    color: #2c2c2c;
    margin: 0 0 18px;
  }
  .option {
    display: block;
    width: 100%;
    text-align: left;
    padding: 14px 18px;
    background: #f7f4f0;
    border: 1px solid #d9d2c9;
    border-radius: 8px;
    cursor: pointer;
    font-size: 1rem;
    color: #3a3a3a;
    font-family: inherit;
    margin-bottom: 12px;
    transition: background 0.15s ease;
  }
  .option:last-child { margin-bottom: 0; }
  .option:hover { background: #ede8e1; }
  .option.selected {
    background: #dcd3c7;
    border: 1px solid #a89e92;
    font-weight: bold;
  }
  .option:focus-visible {
    outline: 2px solid #5b7e5f;
    outline-offset: 2px;
  }
  .quiz-locked .option { cursor: default; }
  .quiz-locked .option:hover { background: #f7f4f0; }
  .quiz-locked .option.selected:hover { background: #dcd3c7; }
  .btn {
    display: block;
    margin: 40px auto 0;
    padding: 16px 40px;
    border: none;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: bold;
    font-family: inherit;
    color: #ffffff;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .btn-eval { background: #5b7e5f; }
  .btn-eval:hover:not(:disabled) { background: #4a6b4e; }
  .btn-eval:disabled {
    background: #b5b5b5;
    cursor: not-allowed;
  }
  .btn-retry {
    background: #8c7b6b;
    margin-top: 24px;
  }
  .btn-retry:hover { background: #756658; }
  .result {
    background: #fefcf9;
    border-radius: 12px;
    border-top: 4px solid #5b7e5f;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    padding: 28px;
    margin-top: 40px;
  }
  .result-name {
    font-size: 2.5rem;
    font-weight: bold;
    color: #5b7e5f;
    text-align: center;
    margin: 0 0 16px;
    line-height: 1.2;
  }
  .result-text {
    font-size: 1rem;
    color: #4a4a4a;
    text-align: center;
    margin: 0 0 8px;
  }
  .result-tie-note {
    font-size: 1rem;
    color: #4a4a4a;
    text-align: center;
    font-style: italic;
    margin: 0 0 24px;
  }
  .result-block { margin-bottom: 28px; }
  .result-block:last-child { margin-bottom: 0; }
  .hidden { display: none; }
  .toast {
    position: fixed;
    left: 50%;
    bottom: 32px;
    transform: translateX(-50%) translateY(20px);
    background: #2c2c2c;
    color: #ffffff;
    padding: 14px 24px;
    border-radius: 8px;
    font-size: 1rem;
    box-shadow: 0 4px 16px rgba(0,0,0,0.25);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
    z-index: 1000;
  }
  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  @media (max-width: 600px) {
    body { padding: 24px 16px; }
    h1 { font-size: 1.55rem; }
    .result-name { font-size: 2rem; }
  }
</style>
</head>
<body>
  <div class="wrap">
    <h1 id="quiz-title"></h1>
    <p class="perex" id="quiz-perex"></p>
    <div id="questions"></div>
    <button type="button" class="btn btn-eval" id="eval-btn" disabled>Vyhodnotit</button>
    <div id="result" class="result hidden" aria-live="polite"></div>
    <button type="button" class="btn btn-retry hidden" id="retry-btn">Zkusit znovu</button>
  </div>
  <div class="toast" id="toast" role="status" aria-live="polite"></div>

<script>
(function () {
  const TITLE = `Test pro seniory: zjistěte, jak mladý je váš mozek. Stačí 10 otázek a dozvíte se věk`;
  const PEREX = `Roky v občance nic neřeknou o tom, jak svěží je vaše hlava. Deset otázek prověří vaši paměť, pohotovost i chuť do nového a napoví, na kolik let se chová váš mozek. Odpovězte upřímně, milí senioři, a nechte se překvapit.`;

  const QUESTIONS = [
    {
      text: `1. Jak vám to jde s vybavováním jmen a drobností?`,
      options: [
        { letter: `a`, text: `vybavíte si je okamžitě a skoro nikdy nezaváháte` },
        { letter: `b`, text: `většinou si vzpomenete rychle, jen párkrát za den chvíli zapátráte` },
        { letter: `c`, text: `chvíli vám to trvá, ale nakonec si na všechno vzpomenete` },
        { letter: `d`, text: `raději si důležité věci zapisujete, ať se nemusíte spoléhat na hlavu` }
      ]
    },
    {
      text: `2. Jak rychle se rozhodujete v běžných situacích?`,
      options: [
        { letter: `a`, text: `skoro bleskově, odpověď máte hned na jazyku` },
        { letter: `b`, text: `svižně a věcně, zbytečně nezdržujete` },
        { letter: `c`, text: `v klidu si to přeberete a pak se rozhodnete` },
        { letter: `d`, text: `necháte si na rozmyšlenou čas a do ničeho se neženete` }
      ]
    },
    {
      text: `3. Jak se orientujete v neznámém městě nebo budově?`,
      options: [
        { letter: `a`, text: `vyrazíte podle citu a cestu si najdete skoro sami` },
        { letter: `b`, text: `rychle se zorientujete podle plánku nebo pár značek` },
        { letter: `c`, text: `postupujete opatrně a raději se cestou zeptáte` },
        { letter: `d`, text: `držíte se osvědčené trasy, kterou už znáte` }
      ]
    },
    {
      text: `4. Jak počítáte při nákupu, kolik zaplatíte?`,
      options: [
        { letter: `a`, text: `sečtete to v hlavě dřív, než dojdete k pokladně` },
        { letter: `b`, text: `spočítáte si to z hlavy, jen si to pro jistotu zkontrolujete` },
        { letter: `c`, text: `pomůžete si prsty nebo si částky srovnáte postupně` },
        { letter: `d`, text: `raději sáhnete po kalkulačce v telefonu` }
      ]
    },
    {
      text: `5. Jak vám jde soustředění, když se kolem děje víc věcí naráz?`,
      options: [
        { letter: `a`, text: `v pohodě sledujete několik věcí zároveň a nic vám neuteče` },
        { letter: `b`, text: `zvládnete to, ale radši si věci odbavíte jednu po druhé` },
        { letter: `c`, text: `potřebujete spíš klid, ať se můžete věnovat jedné věci` },
        { letter: `d`, text: `ruch vás snadno vyruší, a tak si hledáte tichý koutek` }
      ]
    },
    {
      text: `6. Jaký vztah máte k hlavolamům, křížovkám a hrám na přemýšlení?`,
      options: [
        { letter: `a`, text: `vrháte se i do těch nejtěžších a baví vás lámat si s nimi hlavu` },
        { letter: `b`, text: `sáhnete po nich, když chcete rychle protáhnout hlavu` },
        { letter: `c`, text: `luštíte je s chutí, ale spíš v klidu a bez tlaku na čas` },
        { letter: `d`, text: `máte pár oblíbených, u kterých zůstáváte, a nové moc nevyhledáváte` }
      ]
    },
    {
      text: `7. Jak vám jde hledání správných slov, když něco vyprávíte?`,
      options: [
        { letter: `a`, text: `slova se jen sypou a mluvíte plynule a barvitě` },
        { letter: `b`, text: `vyjadřujete se svižně a k věci, bez zbytečného zaobalování` },
        { letter: `c`, text: `občas slovo chvíli hledáte, ale vždycky ho nakonec najdete` },
        { letter: `d`, text: `mluvíte pomaleji a s rozvahou, ať to vyjde přesně` }
      ]
    },
    {
      text: `8. Jak reagujete, když se plán na poslední chvíli změní?`,
      options: [
        { letter: `a`, text: `hned vymyslíte něco nového a berete to jako vítané okoření dne` },
        { letter: `b`, text: `rychle si to přeskládáte a jedete dál podle nové situace` },
        { letter: `c`, text: `chvíli si na změnu zvykáte, ale pak se přizpůsobíte` },
        { letter: `d`, text: `změny vás rozhodí a radši se držíte původní domluvy` }
      ]
    },
    {
      text: `9. Jak si organizujete den, když vás čeká víc úkolů?`,
      options: [
        { letter: `a`, text: `žonglujete s nimi za pochodu a stíháte to i tak` },
        { letter: `b`, text: `sestavíte si rychlý plán a odškrtáváte splněné` },
        { letter: `c`, text: `rozložíte si to v klidu, ať na nic nespěcháte` },
        { letter: `d`, text: `děláte věci po jedné a raději popořadě, jak jste zvyklí` }
      ]
    },
    {
      text: `10. Jak se stavíte k učení nové dovednosti?`,
      options: [
        { letter: `a`, text: `pouštíte se do toho s nadšením a láká vás každá novinka` },
        { letter: `b`, text: `naučíte se to, co vám usnadní život, a jdete dál` },
        { letter: `c`, text: `dáte tomu čas a učíte se svým vlastním tempem` },
        { letter: `d`, text: `vystačíte si s tím, co umíte, a novinky vás moc netáhnou` }
      ]
    }
  ];

  const PROFILES = {
    a: {
      name: `Mozek jako ve třiceti.`,
      text: `Vaše hlava jede na plné obrátky, novým věcem se otevíráte s chutí a v čemkoli se rychle zorientujete. Paměť i pohotovost vám slouží, jako by vám bylo kolem třiceti. Zvědavost vás drží mladé a nenecháte si ujít žádnou příležitost něco se přiučit.`
    },
    b: {
      name: `Mozek v nejlepší formě.`,
      text: `Přemýšlíte svižně, prakticky a jdete rovnou k jádru věci. Umíte si věci zorganizovat, spočítat i pohotově vyřešit, a tak se váš mozek chová jako kolem čtyřicítky. Spojujete rychlost s rozvahou a na to se dá spolehnout.`
    },
    c: {
      name: `Mozek v klidné rovnováze.`,
      text: `Nespěcháte, ale nic vám neunikne, protože věcem dáváte čas a řešíte je s rozvahou. Vaše hlava pracuje vyrovnaně a jistě, tak jako kolem padesátky, a klid je vaší největší silou. Kvalitu upřednostňujete před rychlostí.`
    },
    d: {
      name: `Mozek plný zkušeností.`,
      text: `Spoléháte na to, co znáte, postupujete s rozmyslem a máte za sebou spoustu prožitého. Vaše hlava čerpá z bohaté zásobárny zkušeností a moudrosti, kterou mladší teprve dohánějí. Osvědčené cesty vám dávají jistotu, na které stojí za to stavět.`
    }
  };

  const PROFILE_ORDER = [`a`, `b`, `c`, `d`];

  const answers = new Array(QUESTIONS.length).fill(null);
  let locked = false;

  const titleEl = document.getElementById(`quiz-title`);
  const perexEl = document.getElementById(`quiz-perex`);
  const questionsEl = document.getElementById(`questions`);
  const evalBtn = document.getElementById(`eval-btn`);
  const retryBtn = document.getElementById(`retry-btn`);
  const resultEl = document.getElementById(`result`);
  const toastEl = document.getElementById(`toast`);

  titleEl.textContent = TITLE;
  perexEl.textContent = PEREX;

  function buildQuestions() {
    questionsEl.innerHTML = ``;
    QUESTIONS.forEach(function (q, qi) {
      const box = document.createElement(`div`);
      box.className = `question`;

      const qText = document.createElement(`p`);
      qText.className = `q-text`;
      qText.textContent = q.text;
      box.appendChild(qText);

      q.options.forEach(function (opt, oi) {
        const btn = document.createElement(`button`);
        btn.type = `button`;
        btn.className = `option`;
        btn.textContent = opt.text;
        btn.setAttribute(`data-q`, String(qi));
        btn.setAttribute(`data-o`, String(oi));
        btn.addEventListener(`click`, function () {
          if (locked) return;
          const siblings = box.querySelectorAll(`.option`);
          siblings.forEach(function (s) { s.classList.remove(`selected`); });
          btn.classList.add(`selected`);
          answers[qi] = opt.letter;
          updateEvalState();
        });
        box.appendChild(btn);
      });

      questionsEl.appendChild(box);
    });
  }

  function allAnswered() {
    return answers.every(function (a) { return a !== null; });
  }

  function updateEvalState() {
    evalBtn.disabled = !allAnswered();
  }

  let toastTimer = null;
  function showToast(msg) {
    toastEl.textContent = msg;
    toastEl.classList.add(`show`);
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(function () {
      toastEl.classList.remove(`show`);
    }, 2600);
  }

  function evaluate() {
    if (!allAnswered()) {
      showToast(`Odpovězte prosím na všechny otázky`);
      return;
    }

    locked = true;
    questionsEl.classList.add(`quiz-locked`);

    const counts = { a: 0, b: 0, c: 0, d: 0 };
    answers.forEach(function (a) { counts[a] += 1; });

    let max = 0;
    PROFILE_ORDER.forEach(function (l) {
      if (counts[l] > max) max = counts[l];
    });

    const winners = PROFILE_ORDER.filter(function (l) {
      return counts[l] === max;
    });

    renderResult(winners);

    evalBtn.classList.add(`hidden`);
    retryBtn.classList.remove(`hidden`);
    resultEl.classList.remove(`hidden`);

    resultEl.scrollIntoView({ behavior: `smooth`, block: `start` });
  }

  function renderResult(winners) {
    resultEl.innerHTML = ``;

    if (winners.length > 1) {
      const note = document.createElement(`p`);
      note.className = `result-tie-note`;
      note.textContent = `Vaše odpovědi se rovnoměrně rozdělily mezi více typů — vyšly vám shodně následující:`;
      resultEl.appendChild(note);
    }

    winners.forEach(function (l) {
      const profile = PROFILES[l];
      const block = document.createElement(`div`);
      block.className = `result-block`;

      const nameEl = document.createElement(`div`);
      nameEl.className = `result-name`;
      nameEl.textContent = profile.name;
      block.appendChild(nameEl);

      const textEl = document.createElement(`p`);
      textEl.className = `result-text`;
      textEl.textContent = profile.text;
      block.appendChild(textEl);

      resultEl.appendChild(block);
    });
  }

  function reset() {
    for (let i = 0; i < answers.length; i++) answers[i] = null;
    locked = false;
    questionsEl.classList.remove(`quiz-locked`);

    const selected = questionsEl.querySelectorAll(`.option.selected`);
    selected.forEach(function (s) { s.classList.remove(`selected`); });

    resultEl.classList.add(`hidden`);
    resultEl.innerHTML = ``;
    retryBtn.classList.add(`hidden`);
    evalBtn.classList.remove(`hidden`);
    updateEvalState();

    window.scrollTo({ top: 0, behavior: `smooth` });
  }

  evalBtn.addEventListener(`click`, evaluate);
  retryBtn.addEventListener(`click`, reset);

  buildQuestions();
  updateEvalState();
})();
</script>
</body>
</html>
